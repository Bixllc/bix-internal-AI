# Neon/Postgres connection string.
# Neon dashboard -> Connection Details -> "Prisma" tab gives you this directly.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Google Places API key (Places API + Places API (New) enabled).
GOOGLE_PLACES_API_KEY=""

# OpenAI key used for website analysis / report generation.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Optional. If unset, the app falls back to a basic built-in website fetcher.
FIRECRAWL_API_KEY=""
